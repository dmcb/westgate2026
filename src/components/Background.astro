  <div class="circle circle-1"></div>
  <div class="circle circle-2"></div>
  <div class="circle circle-3"></div>
  <div class="circle circle-4"></div>
  <div class="circle circle-5"></div>

  <div class="stars">
    <svg class="star star-1" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6L12 2z" fill="currentColor"/></svg>
    <svg class="star star-2" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6L12 2z" fill="currentColor"/></svg>
    <svg class="star star-3" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6L12 2z" fill="currentColor"/></svg>
    <svg class="star star-4" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6L12 2z" fill="currentColor"/></svg>
    <svg class="star star-5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6L12 2z" fill="currentColor"/></svg>
    <svg class="star star-6" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6L12 2z" fill="currentColor"/></svg>
    <svg class="star star-7" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6L12 2z" fill="currentColor"/></svg>
    <svg class="star star-8" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6L12 2z" fill="currentColor"/></svg>
  </div>
</section>

<script>
  const section = document.querySelector('.stars')?.closest('section');
  const starsEl = document.querySelectorAll<SVGSVGElement>('.star');

  const starConfig = [
    { orbit: 0.30, speed: 0.00005, angle: 0 },
    { orbit: 0.38, speed: -0.00004, angle: 0.785 },
    { orbit: 0.25, speed: 0.00006, angle: 1.571 },
    { orbit: 0.42, speed: -0.00003, angle: 2.356 },
    { orbit: 0.33, speed: 0.000045, angle: 3.142 },
    { orbit: 0.40, speed: -0.000035, angle: 3.927 },
    { orbit: 0.28, speed: 0.000055, angle: 4.712 },
    { orbit: 0.36, speed: -0.000042, angle: 5.498 },
  ];

  let condense = 0;

  function onScroll() {
    if (!section) return;
    const rect = section.getBoundingClientRect();
    const containerW = section.offsetWidth || 1;
    const scrolled = Math.max(0, -rect.top);
    condense = Math.min(1, scrolled / containerW * 1.5);
  }

  let lastTime = 0;
  function animate(time: number) {
    const dt = lastTime ? time - lastTime : 16;
    lastTime = time;

    if (!section) { requestAnimationFrame(animate); return; }
    const containerW = section.offsetWidth;

    starsEl.forEach((star, i) => {
      const cfg = starConfig[i];
      cfg.angle += cfg.speed * dt;
      const radius = cfg.orbit * containerW * (1 - condense * 0.85);
      const x = Math.cos(cfg.angle) * radius;
      const y = Math.sin(cfg.angle) * radius;
      star.style.transform = `translate(${x}px, ${y}px)`;
    });

    requestAnimationFrame(animate);
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
  requestAnimationFrame(animate);
</script>

