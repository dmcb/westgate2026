---
import westgate from '../assets/westgate.png';
---
<section>
  <img src={westgate.src} alt="Westgate School logo" width="960" height="1059" />
  <h1>Later, Gators!</h1>
  <p>Hello Grade 6 Gator guardians. This site contains important information about the Grade 6 farewell celebration on Thursday, June 25.</p>
</section>

<style>
  section {
    padding: 0 2rem;
    max-width: none;
  }

  img {
    position: relative;
    z-index: 1;
    margin-top: 1rem;
    max-width: clamp(300px, 60vw, 600px);
    height: auto;
  }

  h1 {
    font-family: "Bevan", serif;
    font-weight: 400;
    font-style: normal;
    font-size: clamp(2rem, 10vw, 6rem);
    margin: 1.5rem 0;
  }

  p {
    max-width: 720px;
    font-size: 1.325em;
    margin-left: auto;
    margin-right: auto;
  }

</style>